# ──────────────────────────────────────────────────────────────────────────
# AutoRAG Architect — Environment Variables Template
# Copy this file to .env and fill in the values appropriate for your setup.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────

# ── LLM Providers (at least one required for AI-powered architecture decisions) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=

# ── Vector Database Providers (optional — local Chroma is used as default) ──
PINECONE_API_KEY=
QDRANT_API_KEY=
WEAVIATE_API_KEY=

# ── Application Settings ──────────────────────────────────────────────────
# Comma-separated allowed CORS origins. Leave empty for local dev (allows all).
ALLOWED_ORIGINS=

# Maximum upload file size in megabytes (default: 50)
MAX_UPLOAD_MB=50

# Default local embedding model used when no OpenAI key is present.
DEFAULT_EMBEDDING_MODEL=huggingface_bge

# Number of chunks to retrieve per query (default: 3)
RETRIEVAL_K=3

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Database & Task Queue (Phase 2 — uncomment when using PostgreSQL / Redis) ──
# DATABASE_URL=postgresql://user:password@localhost:5432/autorag
# REDIS_URL=redis://localhost:6379/0

# ── Security ─────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=changeme-replace-before-production
